---
import RemoteImage from './RemoteImage.astro';
import { useTranslations } from '../i18n/ui';
import { coordsLabel, dateLabel, entryLabel } from '../lib/format';
import { localeOf, pathOf, type Trip } from '../lib/trips';

interface Props {
  trip: Trip;
  /** Chronological entry number for the N° label. */
  number?: number;
}

const { trip, number } = Astro.props;
const locale = localeOf(trip);
const t = useTranslations(locale);
const label = [
  t('home.heroLabel'),
  [number !== undefined ? entryLabel(number) : null, `${dateLabel(trip.data.date, locale)} · ${trip.data.country}`]
    .filter(Boolean)
    .join(' '),
].join(' — ');
---

<section class="relative h-[70vh] min-h-[420px]">
  <RemoteImage
    image={trip.data.heroImage}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-navy/85 via-transparent to-navy/20"></div>
  <div class="absolute right-0 bottom-0 left-0">
    <div class="mx-auto max-w-6xl px-5 pb-12 text-white">
      <p class="font-mono text-xs font-semibold tracking-[0.25em] text-brand-red-light uppercase">
        {label}
      </p>
      <h1 class="mt-2 max-w-3xl text-4xl font-extrabold md:text-5xl">{trip.data.title}</h1>
      <p class="mt-3 max-w-xl text-white/85">{trip.data.excerpt}</p>
      <p class="mt-2 font-mono text-xs tracking-[0.15em] text-white/60">
        {coordsLabel(trip.data.coordinates)}
      </p>
      <a
        href={pathOf(trip)}
        class="mt-5 inline-block rounded bg-brand-red px-5 py-2.5 text-sm font-semibold hover:bg-brand-red-light"
      >
        {t('home.readStory')} →
      </a>
    </div>
  </div>
</section>
