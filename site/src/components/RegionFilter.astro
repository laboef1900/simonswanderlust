---
import { useTranslations, type Locale, type UIKey } from '../i18n/ui';
import { homePath, regionPath, regions, type Region } from '../lib/paths';

interface Props {
  locale: Locale;
  active?: Region;
  /** Where the "All" chip points; defaults to the home story grid. */
  allHref?: string;
}

const { locale, active, allHref = homePath(locale) + '#stories' } = Astro.props;
const t = useTranslations(locale);

const chip = 'rounded-full border px-3 py-1 text-sm';
const on = 'border-navy bg-navy text-white';
const off = 'border-navy/20 text-ink/70 hover:border-brand-red hover:text-brand-red';
---

<nav aria-label={t('regions.filterLabel')} class="flex flex-wrap gap-2">
  <a
    href={allHref}
    aria-current={!active ? 'page' : undefined}
    class:list={[chip, active ? off : on]}
  >
    {t('home.filter.all')}
  </a>
  {
    regions.map((region) => (
      <a
        href={regionPath(region, locale)}
        aria-current={active === region ? 'page' : undefined}
        class:list={[chip, active === region ? on : off]}
      >
        {t(`region.${region}` as UIKey)}
      </a>
    ))
  }
</nav>
