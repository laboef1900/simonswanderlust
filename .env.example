# Environment for the root docker-compose.yml (blog-builder + blog nginx + uploader + db).
# Copy to .env and fill in real values before `docker compose up -d --build`.
# The stack now includes a Postgres container (db) and a blog-builder service,
# so these vars are required — not just for the uploader.

# ── Postgres (required) ─────────────────────────────────────────────────────
POSTGRES_USER=images
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=images

# Connection string used by blog-builder and uploader. Inside Docker the host is "db".
# For local `npm run dev` against a local Postgres, use 127.0.0.1 instead.
DATABASE_URL=postgres://images:change-me-to-a-long-random-string@db:5432/images

# ── Build trigger secret (required) ─────────────────────────────────────────
# Used by the blog-builder HTTP endpoint (/build) and the uploader's rebuild button.
BUILD_SECRET=change-me-to-a-long-random-string
# Internal URL of the blog-builder the uploader calls on Publish.
BUILDER_URL=http://blog-builder:4000

# ── Image uploader ───────────────────────────────────────────────────────────
# Public base URL where uploaded image variants are served (your img. subdomain).
PUBLIC_BASE_URL=https://img.simonswanderlust.com
# Local vision model (LM Studio, OpenAI-compatible) for AI alt/slug suggestions.
# Captioning runs in your browser, so this is the URL YOUR BROWSER uses to reach
# LM Studio (usually localhost). Seeds the default until changed on the settings page.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3-vl-4b

# ── Blog nginx ───────────────────────────────────────────────────────────────
# Host port the blog (nginx) is published on. Default 8090 (8080 is often taken).
BLOG_PORT=8090
