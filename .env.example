# Environment for the root docker-compose.yml (blog + uploader).
# Copy to .env and fill in. Only the uploader needs these; the blog is static.

# Host port the blog (nginx) is published on. Default 8090 (8080 is often taken).
BLOG_PORT=8090

# Bearer token required for uploads. Generate a long random value.
AUTH_TOKEN=change-me-to-a-long-random-string
# Public URL where uploaded images are served (your img. subdomain).
PUBLIC_BASE_URL=https://img.simonswanderlust.com
# Local vision model (LM Studio). The admin pages call it from YOUR BROWSER, so this
# is the URL your browser uses to reach LM Studio (usually localhost). Seeds the default
# until you change it on the settings page.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3-vl-4b
# Where the uploader persists runtime LLM settings (defaults next to STORAGE_DIR).
# SETTINGS_PATH=/data/settings.json
